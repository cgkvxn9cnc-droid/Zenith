    },
    "develop.footer.reset_group_hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Up to three panels can stay open. Hover a panel title or any control in that group, then press ⌘⌥= to reset the whole group."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois panneaux au maximum restent ouverts. Survolez le titre d’un groupe ou un de ses réglages, puis ⌘⌥= pour réinitialiser tout le groupe."
          }
        }
      }
    },
    "develop.global_saturation" : {
      "extractionState" : "stale",
