    "settings.color.preview.footer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Display P3 uses wide-gamut output when your display supports it. CMYK soft proof shows a reminder for CMYK assets; it does not simulate full print separation."
          }
