    "settings.color.section.footer" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Embedded ICC profiles are read from files. Untagged RGB uses the profile you choose. Display P3 uses wide-gamut output when your display supports it. CMYK soft proof adds an on-screen note for CMYK sources; full separation simulation may follow in a later version."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les profils ICC embarqués sont lus dans les fichiers. Les RVB non taggés utilisent le profil choisi. Display P3 produit une sortie large gamme si l’écran le permet. La preuve CMJN ajoute une indication à l’écran pour les sources CMJN ; une simulation complète pourra suivre."
          }
        }
      }
    },
    "settings.color.source.footer" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Embedded ICC profiles are read from tagged files. Untagged RGB images use the profile below, then are converted to Zenith’s Develop linear working space."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les profils ICC embarqués sont lus pour les fichiers tagués. Les images RVB non taguées utilisent le profil ci-dessous, puis sont converties vers l’espace de travail linéaire Develop de Zenith."
          }
        }
      }
    },
