    "develop.grain.hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CIRandomGenerator (cropped), Gaussian blur controls particle size, high-pass removes DC; luminance extracted via Rec.709 matrix; additive blend with original, masked by a bell-shaped CIToneCurve on scene luminance (midtones strongest). Roughness mixes a finer, higher-contrast noise branch. Noise pattern is deterministic across frames unless you perturb externally—film-static vs cinema grain."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "`CIRandomGenerator` recadré, flou Gaussien pour la taille, passe‑haut pour retirer le DC ; luminance Rec.709 puis addition avec l’originale masquée par une cloche `CIToneCurve` sur la luminance (tons moyens). Rugosité : mélange avec une voie plus fine et contrastée. Texture déterministe entre images tant que le générateur n’est pas perturbé (grain figé vs grain vivant)."
          }
        }
      }
    },
