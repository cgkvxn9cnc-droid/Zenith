    "develop.sharpness.hint" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Three-band linear RGB unsharp mask (structure → contours → detail) before display gamma. Threshold softening per band; Sobel edge blend protects flats; highlights tapered by luminance. Uses CIContext linear working space. Preview debounced."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trois passes USM **RVB linéaires** (structure large rayon → contours → détail fin), avant le gamma d’affichage ; seuil doux par bande ; masque Sobel pour les aplats ; atténuation progressive dans les hautes lumières. Espace de travail linéaire du `CIContext`. Aperçu debouncé."
          }
        }
      }
    },
